{
  "name": "systems-build-log-site",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "sync:data": "node scripts/sync-public-assets.mjs",
    "measure:books": "node scripts/measure-bookops-books.mjs",
    "predev": "npm run sync:data",
    "dev": "vite --host 127.0.0.1",
    "prebuild": "npm run sync:data",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "verify:local": "node scripts/verify-local.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3"
  }
}
